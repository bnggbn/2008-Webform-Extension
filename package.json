{
  "name": "vscodefor08",
  "displayName": "WebForms Helper for VS2008",
  "description": "Navigation-first helper for legacy ASP.NET WebForms / WebSite projects.",
  "version": "0.0.1",
  "publisher": "bnggbn",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:csharp",
    "onLanguage:webforms-aspx",
    "onCommand:webformsHelper.goToCodeBehind",
    "onCommand:webformsHelper.goToMarkup",
    "onCommand:webformsHelper.goToDesigner",
    "onCommand:webformsHelper.refreshRelationships",
    "onView:webformsHelper.relatedFiles"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "webforms-aspx",
        "aliases": [
          "WebForms ASPX",
          "ASPX"
        ],
        "extensions": [
          ".aspx",
          ".ascx",
          ".master"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "webforms-aspx",
        "scopeName": "text.html.webforms",
        "path": "./syntaxes/webforms-aspx.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.js.embedded.html": "javascript",
          "source.css": "css",
          "source.css.embedded.html": "css",
          "meta.embedded.block.asp": "csharp",
          "meta.embedded.block.asp.expression": "csharp",
          "meta.embedded.block.asp.directive": "csharp"
        }
      }
    ],
    "snippets": [
      {
        "language": "webforms-aspx",
        "path": "./snippets/webforms-aspx.code-snippets"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.aspx": "webforms-aspx",
        "*.ascx": "webforms-aspx",
        "*.master": "webforms-aspx"
      }
    },
    "commands": [
      {
        "command": "webformsHelper.goToCodeBehind",
        "title": "WebForms: Go to Code Behind"
      },
      {
        "command": "webformsHelper.goToMarkup",
        "title": "WebForms: Go to Markup"
      },
      {
        "command": "webformsHelper.goToDesigner",
        "title": "WebForms: Go to Designer"
      },
      {
        "command": "webformsHelper.refreshRelationships",
        "title": "WebForms: Refresh Relationships"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "webformsHelper.relatedFiles",
          "name": "WebForms Related Files"
        }
      ]
    },
    "configuration": {
      "title": "WebForms Helper",
      "properties": {
        "webformsHelper.enableCodeLens": {
          "type": "boolean",
          "default": true
        },
        "webformsHelper.enableDiagnostics": {
          "type": "boolean",
          "default": true
        },
        "webformsHelper.debug.embeddedLanguageLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose embedded JS/CSS parser and projection logs in Output > WebForms Helper."
        },
        "webformsHelper.includeGlobs": {
          "type": "array",
          "default": [
            "**/*.{aspx,ascx,master,ashx,asmx}",
            "**/*.cs"
          ],
          "items": {
            "type": "string"
          }
        },
        "webformsHelper.excludeGlobs": {
          "type": "array",
          "default": [
            "**/bin/**",
            "**/obj/**",
            "**/node_modules/**",
            "**/tools/_intellisense/**"
          ],
          "items": {
            "type": "string"
          }
        },
        "webformsHelper.compatibility.profile": {
          "type": "string",
          "enum": [
            "vs2005",
            "vs2008",
            "vs2010",
            "vs2012",
            "vs2013",
            "vs2015",
            "custom"
          ],
          "default": "vs2008",
          "description": "Legacy compatibility profile used by syntax rules."
        },
        "webformsHelper.compatibility.csharpLanguageVersion": {
          "type": "string",
          "default": "",
          "description": "Used when compatibility.profile is custom. Examples: 3.0, 4.0, 6.0."
        },
        "webformsHelper.rules.missingCodeFile": {
          "type": "string",
          "default": "warning"
        },
        "webformsHelper.rules.missingDesigner": {
          "type": "string",
          "default": "information"
        },
        "webformsHelper.rules.missingInherits": {
          "type": "string",
          "default": "warning"
        },
        "webformsHelper.rules.unsupportedStringInterpolation": {
          "type": "string",
          "default": "error"
        },
        "webformsHelper.rules.unsupportedNameofExpression": {
          "type": "string",
          "default": "error"
        },
        "webformsHelper.rules.unsupportedNullConditionalAccess": {
          "type": "string",
          "default": "error"
        },
        "webformsHelper.rules.embeddedJavaScriptParseError": {
          "type": "string",
          "default": "warning"
        },
        "webformsHelper.rules.embeddedCssParseError": {
          "type": "string",
          "default": "warning"
        },
        "webformsHelper.rules.unclosedAspServerTag": {
          "type": "string",
          "default": "warning",
          "description": "Report unclosed ASP server tags (<% ... without %>) in embedded script/style/attributes."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run build && node --test test/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
